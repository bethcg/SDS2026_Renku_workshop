import torch
from transformers import pipeline
import os

# 1. Initialize pipeline (uses the pre-cached weights)
summarizer = pipeline("summarization", model="google/flan-t5-small", device=-1)

# 2. Load input data
## 2.1 Ensure that the path to the data folder is correct depending on the mounting point of your data connector.
data_path = 'data/stories/input_text.txt'
if os.path.exists(data_path):
    with open(data_path, 'r') as f:
        text_to_summarize = f.read()
else:
    text_to_summarize = "Renku is a platform that allows researchers to track data, code, and compute."

# 3. Generate summary
summary = summarizer(text_to_summarize, max_length=50, min_length=10, do_sample=False)

print("--- Original Text ---")
print(text_to_summarize)
print("\n--- AI Summary ---")
print(summary[0]['summary_text'])

# 4. Save output (for lineage)
with open('outputs/summary.txt', 'w') as f:
    f.write(summary[0]['summary_text'])
